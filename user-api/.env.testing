# ============================================
# Environment: Testing - GCP Cloud Run
# ============================================
NODE_ENV=testing
PORT=8080

# MongoDB Atlas - Testing Database
MONGODB_URI=mongodb+srv://<USERNAME>:<PASSWORD>@<TEST-CLUSTER>.mongodb.net/users_db_test

# GCP Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# API Endpoints (Testing)
ORDER_API_URL=https://order-api-test-xxxxxxxx-uc.a.run.app
PRODUCT_API_URL=https://api.product-api-aws-test.com

# Logging
LOG_LEVEL=debug

# Security
CORS_ALLOWED_ORIGINS=https://order-api-test-xxxxxxxx-uc.a.run.app,https://api.product-api-aws-test.com
