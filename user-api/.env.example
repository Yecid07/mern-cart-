# ============================================
# Environment Template
# ============================================
# Copy this file and rename to .env.<environment>
# Then fill in your specific values

NODE_ENV=development
PORT=3002

# MongoDB Connection String
# Format: mongodb+srv://username:password@cluster.mongodb.net/database
MONGODB_URI=

# GCP Configuration
GCP_PROJECT_ID=
GCP_REGION=us-central1
GCP_CLUSTER=user-api-cluster

# API Endpoints
ORDER_API_URL=http://localhost:3001
PRODUCT_API_URL=http://localhost:3000

# Logging Level (debug, info, warn, error)
LOG_LEVEL=info

# CORS Configuration
CORS_ALLOWED_ORIGINS=*

# Service Info
SERVICE_NAME=user-api
SERVICE_VERSION=2.0
