{
  "extends": ["@commitlint/config-conventional"],
  "rules": {
    "type-enum": [
      2,
      "always",
      [
        "feat",
        "fix",
        "docs",
        "style",
        "refactor",
        "perf",
        "test",
        "chore",
        "ci",
        "🎉",
        "✨",
        "🐛",
        "🔥",
        "📚",
        "🔒",
        "⬆️",
        "⬇️",
        "🎨",
        "♻️",
        "📦",
        "🚀",
        "✅",
        "🔗",
        "💥",
        "🗑️"
      ]
    ],
    "subject-case": [2, "never", ["upper-case"]],
    "type-case": [2, "never", ["upper-case"]]
  },
  "plugins": [
    {
      "rules": {
        "gitmoji-enum": [
          2,
          "always",
          ["🎉", "✨", "🐛", "🔥", "📚", "🔒", "⬆️", "⬇️", "🎨", "♻️", "📦", "🚀", "✅", "🔗", "💥", "🗑️"]
        ]
      }
    }
  ]
}
